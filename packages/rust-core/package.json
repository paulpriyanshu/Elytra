{
  "name": "elytra-wasm",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "import": "./pkg/elytra_wasm.js",
      "types": "./pkg/elytra_wasm.d.ts"
    }
  },
  "scripts": {
    "build": "RUSTFLAGS='-C target-feature=+simd128' wasm-pack build --target web --release",
